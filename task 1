#include <map>
#include <vector>
#include <string>
#include <algorithm>

class Event {
public:
    std::string type;
    void* data;  // для простоты используем void*
    
    Event(const std::string& t, void* d = nullptr) : type(t), data(d) {}
};

class EventListener {
public:
    virtual ~EventListener() {}
    virtual void onEvent(const Event& event) = 0;
    
    // метод для фильтрации - по умолчанию пропускаем все события
    virtual bool filterEvent(const Event& event) {
        return true;  // true - событие проходит фильтр
    }
};

struct ListenerEntry {
    EventListener* listener;
    int priority;  // чем больше число, тем выше приоритет
    
    ListenerEntry(EventListener* l, int p = 0) : listener(l), priority(p) {}
    
    // для сортировки по приоритету (высший первым)
    bool operator<(const ListenerEntry& other) const {
        return priority > other.priority;
    }
};

class EventDispatcher {
private:
    std::map<std::string, std::vector<ListenerEntry>> listeners;
    
public:
    void addListener(const std::string& eventType, EventListener* listener, int priority = 0) {
        if (!listener) return;
        
        auto& vec = listeners[eventType];
        
        // проверяем, нет ли уже такого слушателя
        for (auto& entry : vec) {
            if (entry.listener == listener) {
                entry.priority = priority;  // обновляем приоритет
                sortListeners(vec);
                return;
            }
        }
        
        // добавляем нового слушателя
        vec.push_back(ListenerEntry(listener, priority));
        sortListeners(vec);
    }
    
    void removeListener(const std::string& eventType, EventListener* listener) {
        if (!listener) return;
        
        auto it = listeners.find(eventType);
        if (it != listeners.end()) {
            auto& vec = it->second;
            vec.erase(
                std::remove_if(vec.begin(), vec.end(),
                    [listener](const ListenerEntry& entry) {
                        return entry.listener == listener;
                    }),
                vec.end()
            );
            
            // если вектор пуст, удаляем запись из map
            if (vec.empty()) {
                listeners.erase(it);
            }
        }
    }
    
    void dispatchEvent(const Event& event) {
        auto it = listeners.find(event.type);
        if (it != listeners.end()) {
            // копируем список, чтобы избежать проблем при модификации во время рассылки
            auto listenersCopy = it->second;
            
            for (auto& entry : listenersCopy) {
                // применяем фильтр
                if (entry.listener->filterEvent(event)) {
                    entry.listener->onEvent(event);
                }
            }
        }
    }
    
    // дополнительный метод для подписки на все события
    void addGlobalListener(EventListener* listener, int priority = 0) {
        addListener("*", listener, priority);
    }
    
private:
    void sortListeners(std::vector<ListenerEntry>& vec) {
        std::sort(vec.begin(), vec.end());
    }
};
